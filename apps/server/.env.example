# ---------------------------------------------------------------------------
# Chiron BACKEND environment. Copy to apps/server/.env and fill in real values.
# Every variable is OPTIONAL: with none set, the backend runs in MOCK MODE
# (rule-based agent + in-memory seed events) so you can boot it immediately.
# ---------------------------------------------------------------------------

# --- HTTP server -----------------------------------------------------------
# Port the backend listens on (Cloudflare / your reverse proxy fronts this).
PORT=8787
# Comma-separated browser origins allowed via CORS (the web app, etc.).
# Use "*" for local dev; lock this down in production.
# e.g. ALLOWED_ORIGINS=https://chiron.example,http://localhost:3000
ALLOWED_ORIGINS=*

# Log every HTTP request + agent/LLM step to the terminal (local debugging).
VERBOSE_LOGGING=true

# --- LLM provider selection ------------------------------------------------
# openai | local | mock | auto (default).
# "auto" picks OpenAI when OPENAI_API_KEY is set, else local when
# LOCAL_LLM_ENABLED=true, else mock.
# openai | local | mock | auto (default).
LLM_PROVIDER=auto

# --- OpenAI (hosted) -------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Local model fallback (OpenAI-compatible server) -----------------------
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=Qwen3-8B-Q4_K_M.gguf
LOCAL_LLM_API_KEY=sk-local

# --- Supabase (events database) --------------------------------------------
# When both URL + anon key are set, the events repository reads/writes Supabase.
# Server-side names are preferred; NEXT_PUBLIC_* names are also accepted.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only key for privileged writes. Falls back to the anon key if omitted.
SUPABASE_SERVICE_ROLE_KEY=

# --- VAPI (voice telephony via Custom LLM) ---------------------------------
# Bearer token VAPI sends when calling POST /v1/chat/completions.
# When unset, the endpoint accepts unauthenticated requests (local dev only).
VAPI_LLM_API_KEY=
# Set to "false" to disable the /v1/chat/completions route.
VAPI_ENABLED=true

# --- VAPI outbound calls (organizer outreach) ------------------------------
# API key from https://dashboard.vapi.ai (Account → API Keys).
VAPI_API_KEY=
# Phone number ID from VAPI dashboard → Phone Numbers (the number you dial from).
VAPI_PHONE_NUMBER_ID=
# Optional: saved assistant for outbound organizer calls. When unset, a transient
# assistant is created per call.
VAPI_OUTBOUND_ASSISTANT_ID=
# Optional ElevenLabs voice id for transient outbound assistants.
VAPI_VOICE_ID=
# Public HTTPS URL where VAPI can POST end-of-call-report (ngrok or prod API).
# e.g. https://abc123.ngrok-free.app or https://api.yourdomain.com
VAPI_WEBHOOK_BASE_URL=

# --- Demo: manual outbound user check-in -----------------------------------
# Profile id to call when pressing "Demo: Call user" in the web app.
DEMO_CALL_PROFILE_ID=usr_maria_chen
# Number the demo button dials (E.164). Defaults to +16479681128.
DEMO_CALL_USER_PHONE=+16479681128
