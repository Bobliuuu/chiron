# Chiron WEB frontend environment. Copy to apps/web/.env.local.
#
# The web app is a thin client — it holds NO secrets. It only needs to know
# where the standalone backend lives.
#
# Dev: leave NEXT_PUBLIC_API_URL unset — requests go through the same-origin
# proxy at /chiron-api (see next.config.mjs). Override for direct access:
#   NEXT_PUBLIC_API_URL=http://localhost:8787
#
# Prod: point at the backend's custom domain (e.g. https://api.chiron.example).
# NEXT_PUBLIC_API_URL=https://api.chiron.example
#
# Optional: backend URL for the dev proxy (server-side only, default 127.0.0.1:8787).
# CHIRON_BACKEND_URL=http://127.0.0.1:8787

# Log API calls to the browser console (on by default in dev).
NEXT_PUBLIC_VERBOSE_LOGGING=true

# --- Supabase Auth (required for sign-in) ----------------------------------
# Same project as the backend. The anon key is public by design.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
