# ---------------------------------------------------------------------------
# Chiron WhatsApp bot. Copy to apps/whatsapp/.env and fill in real values.
# The bot is a thin client — all LLM + agent logic lives in the backend.
# ---------------------------------------------------------------------------

# Port this webhook server listens on.
PORT=8788

# Chiron backend base URL (same one the web app uses).
CHIRON_API_URL=http://localhost:8787

# --- Meta WhatsApp Business Cloud API --------------------------------------
# Create an app at https://developers.facebook.com/ and add the WhatsApp product.
# See docs/whatsapp.md for the full setup walkthrough.

# Token you choose — Meta sends this back during webhook verification.
WHATSAPP_VERIFY_TOKEN=your-verify-token-here

# Permanent access token from the Meta developer dashboard.
WHATSAPP_ACCESS_TOKEN=

# Phone number ID from WhatsApp → API Setup (not the display phone number).
WHATSAPP_PHONE_NUMBER_ID=

# App secret — used to verify X-Hub-Signature-256 on incoming webhooks.
# When unset, signature verification is skipped (local dev only).
WHATSAPP_APP_SECRET=
