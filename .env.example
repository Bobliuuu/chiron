# ---------------------------------------------------------------------------
# Chiron environment configuration.
# Copy this file to `.env.local` and fill in real values.
# Every variable is OPTIONAL: with none set, the app runs in MOCK MODE
# (rule-based agent + in-memory seed events) so you can demo immediately.
# ---------------------------------------------------------------------------

# --- LLM provider selection ------------------------------------------------
# openai | local | mock | auto (default).
# "auto" resolves to: openai (if OPENAI_API_KEY set) -> local (if enabled) -> mock.
LLM_PROVIDER=auto

# --- OpenAI (hosted) -------------------------------------------------------
# When set, the orchestrator uses real OpenAI tool-calling.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Local model fallback (no OpenAI key needed) ---------------------------
# Runs a local GGUF model via any OpenAI-compatible server (llama.cpp's
# llama-server, Ollama, or LM Studio). See docs/local-model.md.
# Set to "true" to enable the local fallback (otherwise auto mode uses mock).
LOCAL_LLM_ENABLED=false
# OpenAI-compatible endpoint. llama-server default is shown below.
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
# Model name/path as your local server reports it.
LOCAL_LLM_MODEL=Qwen3.5-9B-Q4_K_M.gguf
# Most local servers ignore this but require a non-empty value.
LOCAL_LLM_API_KEY=sk-local

# --- Supabase (events database) --------------------------------------------
# When both are set, the events repository reads/writes Supabase.
# When unset, an in-memory seeded store is used instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key for privileged writes (never expose to the browser).
# Optional: falls back to the anon key if omitted.
SUPABASE_SERVICE_ROLE_KEY=
